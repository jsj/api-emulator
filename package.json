{
  "name": "api-emulator-monorepo",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "sync-versions": "node scripts/sync-versions.mjs"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "^5.7",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "packages/@api-emulator/adapter-next",
    "packages/@api-emulator/core",
    "apps/*",
    "examples/*"
  ]
}
