{
  "name": "api-emulator",
  "version": "0.6.0",
  "description": "Local API emulators you can run, share, and extend with plugins",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "homepage": "https://api-emulator.jsj.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsj/api-emulator.git",
    "directory": "packages/api-emulator"
  },
  "bugs": {
    "url": "https://github.com/jsj/api-emulator/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "emulator",
    "mock",
    "api",
    "vercel",
    "github",
    "google",
    "oauth",
    "testing",
    "ci",
    "local-development"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "api": "./dist/index.js"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@api-emulator/core": "0.6.0",
    "commander": "^14",
    "picocolors": "^1.1.1",
    "yaml": "^2"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
