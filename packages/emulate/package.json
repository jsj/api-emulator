{
  "name": "api-emulator",
  "version": "0.5.1",
  "description": "Local API emulators you can run, share, and extend with plugins",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "homepage": "https://api-emulator.jsj.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsj/api-emulator.git",
    "directory": "packages/emulate"
  },
  "bugs": {
    "url": "https://github.com/jsj/api-emulator/issues"
  },
  "keywords": [
    "emulator",
    "mock",
    "api",
    "vercel",
    "github",
    "google",
    "oauth",
    "testing",
    "ci",
    "local-development"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "api": "./dist/index.js",
    "api-emulator": "./dist/index.js"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "commander": "^14",
    "picocolors": "^1.1.1",
    "yaml": "^2",
    "@emulators/core": "0.5.0",
    "@emulators/github": "0.5.0",
    "@emulators/apple": "0.5.0",
    "@emulators/microsoft": "0.5.0",
    "@emulators/okta": "0.5.0",
    "@emulators/aws": "0.5.0",
    "@emulators/google": "0.5.0",
    "@emulators/mongoatlas": "0.5.0",
    "@emulators/slack": "0.5.0",
    "@emulators/vercel": "0.5.0",
    "@emulators/resend": "0.5.0",
    "@emulators/stripe": "0.5.0",
    "@emulators/clerk": "0.5.0"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
